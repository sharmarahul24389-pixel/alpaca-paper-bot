# ── Alpaca Paper Trading ─────────────────────────────────────────────────────
# Get these from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true          # keep true for paper trading

# ── Auto-trade filters ────────────────────────────────────────────────────────
AUTO_MIN_GRADE=B            # minimum grade: A / B / C
AUTO_MIN_CONFIDENCE=65      # minimum signal confidence %
AUTO_MAX_DAILY_LOSS=1000    # halt all trading if account drops this much today
AUTO_MAX_SIGNALS=3          # max auto-trades per day

# ── Twilio WhatsApp (same as your existing signal bot) ───────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+971xxxxxxxxx

# ── Signal filters (optional overrides) ──────────────────────────────────────
MIN_CONFIDENCE=60
